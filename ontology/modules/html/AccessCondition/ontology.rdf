      </datacite:Identifier>
    </datacite:hasIdentifier>
    <rdfs:comment xml:lang="en">Access or use of the resource is restricted.</rdfs:comment>
    <skos:exactMatch rdf:resource="https://vocabularies.coar-repositories.org/access_rights/c_16ec/"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/all_rights_reserved">
    <rdf:type rdf:resource="https://gotriple.eu/ontology/triple/AccessCondition"/>
