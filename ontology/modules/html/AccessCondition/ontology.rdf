      <datacite:Identifier rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/acr_public-domain">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
      </datacite:Identifier>
    </datacite:hasIdentifier>
    <rdfs:comment xml:lang="en">The resource is in the public domain.</rdfs:comment>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/metadata_only_access">
