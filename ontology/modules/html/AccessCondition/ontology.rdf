      </datacite:Identifier>
    </datacite:hasIdentifier>
    <rdfs:comment xml:lang="en">Only the metadata of the resource is accessible.</rdfs:comment>
    <skos:exactMatch rdf:resource="https://vocabularies.coar-repositories.org/access_rights/c_14cb/"/>
  </owl:NamedIndividual>
