    <datacite:hasIdentifier>
      <datacite:Identifier rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/acr_other">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
      </datacite:Identifier>
    </datacite:hasIdentifier>
    <rdfs:comment xml:lang="en">Other access conditions not listed in the vocabulary.</rdfs:comment>
  </owl:NamedIndividual>
  <owl:Ontology rdf:about="https://gotriple.eu/ontology/triple/AccessCondition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:title xml:lang="en">Access Condition</dcterms:title>
    <dcterms:description xml:lang="en">The Access Condition vocabulary defines the access rights associated with resources in the TRIPLE platform, such as Open Access, Restricted Access, or Closed Access. It facilitates the filtering and identification of resource availability.</dcterms:description>
    <dcterms:abstract xml:lang="en">A controlled vocabulary for specifying access conditions, aligned with COAR Access Rights where applicable.</dcterms:abstract>
    <dcterms:creator>Alessandro Bertozzi</dcterms:creator>
    <dcterms:contributor>Luca De Santis</dcterms:contributor>
    <dcterms:contributor>Silvio Peroni</dcterms:contributor>
    <owl:versionInfo>2.1.0</owl:versionInfo>
    <vann:preferredNamespacePrefix>accesscondition</vann:preferredNamespacePrefix>
    <vann:preferredNamespaceUri>https://gotriple.eu/ontology/triple/AccessCondition/</vann:preferredNamespaceUri>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-12-01</dcterms:created>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-07-10</dcterms:modified>
    <rdfs:label xml:lang="en">Access Condition</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.org/dc/terms/RightsStatement"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </owl:Ontology>
</rdf:RDF>
