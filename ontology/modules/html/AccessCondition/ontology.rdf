    <rdfs:label xml:lang="en">Public Domain</rdfs:label>
    <rdfs:label xml:lang="pt">Domínio Púlico</rdfs:label>
    <rdfs:label xml:lang="pl">Domena publiczna</rdfs:label>
    <rdfs:label xml:lang="fr">Domaine Public</rdfs:label>
