  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/closed_access">
    <rdf:type rdf:resource="https://gotriple.eu/ontology/triple/AccessCondition"/>
