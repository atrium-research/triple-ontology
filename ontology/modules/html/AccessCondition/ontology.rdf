      </datacite:Identifier>
    </datacite:hasIdentifier>
    <rdfs:comment xml:lang="en">All rights are reserved by the copyright holder.</rdfs:comment>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/free_access">
    <rdf:type rdf:resource="https://gotriple.eu/ontology/triple/AccessCondition"/>
    <rdfs:label xml:lang="en">Free Access</rdfs:label>
    <rdfs:label xml:lang="pt">Acesso Livre</rdfs:label>
    <rdfs:label xml:lang="pl">Bezpłatny dostęp</rdfs:label>
    <rdfs:label xml:lang="fr">Accès Libre</rdfs:label>
    <datacite:hasIdentifier>
      <datacite:Identifier rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/acr_free-access">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
      </datacite:Identifier>
    </datacite:hasIdentifier>
    <rdfs:comment xml:lang="en">Access to the resource is free of charge.</rdfs:comment>
    <skos:closeMatch rdf:resource="https://vocabularies.coar-repositories.org/access_rights/c_abf2/"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/public_domain">
