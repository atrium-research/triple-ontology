    <rdfs:label xml:lang="pl">Zamknięty dostęp</rdfs:label>
    <rdfs:label xml:lang="fr">Accès Fermé</rdfs:label>
    <datacite:hasIdentifier>
      <datacite:Identifier rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/acr_closed-access">
