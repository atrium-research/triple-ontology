      </datacite:Identifier>
    </datacite:hasIdentifier>
    <rdfs:comment xml:lang="en">Only the metadata of the resource is accessible.</rdfs:comment>
    <skos:exactMatch rdf:resource="https://vocabularies.coar-repositories.org/access_rights/c_14cb/"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/undefined">
    <rdf:type rdf:resource="https://gotriple.eu/ontology/triple/AccessCondition"/>
    <rdfs:label xml:lang="en">Undefined</rdfs:label>
    <rdfs:label xml:lang="pt">Indefinido</rdfs:label>
    <rdfs:label xml:lang="pl">Nieokreślone</rdfs:label>
    <rdfs:label xml:lang="fr">Non Défini</rdfs:label>
    <datacite:hasIdentifier>
      <datacite:Identifier rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/acr_undefined">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
      </datacite:Identifier>
    </datacite:hasIdentifier>
    <rdfs:comment xml:lang="en">Access condition is undefined or unknown.</rdfs:comment>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/embargoed_access">
    <rdf:type rdf:resource="https://gotriple.eu/ontology/triple/AccessCondition"/>
    <rdfs:label xml:lang="en">Embargoed Access</rdfs:label>
    <datacite:hasIdentifier>
      <datacite:Identifier rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/acr_embargoed-access">
