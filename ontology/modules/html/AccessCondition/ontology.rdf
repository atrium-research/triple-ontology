      </datacite:Identifier>
    </datacite:hasIdentifier>
    <rdfs:comment xml:lang="en">Access to the resource is closed.</rdfs:comment>
    <skos:closeMatch rdf:resource="https://vocabularies.coar-repositories.org/access_rights/c_14cb/"/>
