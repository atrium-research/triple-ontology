  <owl:NamedIndividual rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/open_access">
    <rdf:type rdf:resource="https://gotriple.eu/ontology/triple/AccessCondition"/>
    <rdfs:label xml:lang="en">Open Access</rdfs:label>
    <rdfs:label xml:lang="pt">Acesso Aberto</rdfs:label>
    <rdfs:label xml:lang="pl">Otwarty dostęp</rdfs:label>
    <rdfs:label xml:lang="fr">Accès Ouvert</rdfs:label>
    <datacite:hasIdentifier>
      <datacite:Identifier rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/acr_open-access">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
      </datacite:Identifier>
    </datacite:hasIdentifier>
    <rdfs:comment xml:lang="en">The resource is available under an open license.</rdfs:comment>
    <skos:exactMatch rdf:resource="https://vocabularies.coar-repositories.org/access_rights/c_abf2/"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/restricted_access_or_use">
    <rdf:type rdf:resource="https://gotriple.eu/ontology/triple/AccessCondition"/>
    <rdfs:label xml:lang="en">Restricted access or use</rdfs:label>
    <rdfs:label xml:lang="pt">Acesso ou Uso Restrito</rdfs:label>
    <rdfs:label xml:lang="pl">Ograniczony dostęp lub użycie</rdfs:label>
    <rdfs:label xml:lang="fr">Accès ou Utilisation Restreints</rdfs:label>
