  <owl:NamedIndividual rdf:about="https://gotriple.eu/ontology/triple/AccessCondition/other">
    <rdf:type rdf:resource="https://gotriple.eu/ontology/triple/AccessCondition"/>
    <rdfs:label xml:lang="en">Other</rdfs:label>
