  <owl:Ontology rdf:about="https://gotriple.eu/ontology/triple/License">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:title xml:lang="en">License</dcterms:title>
    <dcterms:description xml:lang="en">The License vocabulary enumerates the standard licenses used to release resources/items in the TRIPLE platform, including Creative Commons licenses and other open or proprietary licenses.</dcterms:description>
