  <owl:Ontology rdf:about="https://gotriple.eu/ontology/triple/Dataset">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Dataset</rdfs:label>
    <rdfs:label xml:lang="en">Dataset (Triple)</rdfs:label>
    <rdfs:label xml:lang="pt">Base de Dados</rdfs:label>
    <rdfs:label xml:lang="pl">Zbiór Danych</rdfs:label>
    <rdfs:label xml:lang="fr">Jeu de Données</rdfs:label>
    <dcterms:title xml:lang="en">Dataset</dcterms:title>
    <dcterms:abstract xml:lang="en">The Dataset module of the TRIPLE Ontology, defining Datasets and Distributions aligned with DCAT.</dcterms:abstract>
    <dcterms:description xml:lang="en">The Dataset module specializes in representing research data. It defines `triple:Dataset` as a connection point to the DCAT ontology, supporting the description of datasets, their distributions, temporal/spatial coverage, and access rights. This facilitates the discovery and reuse of research data within the SSH domain.</dcterms:description>
    <dcterms:created>2021-12-01</dcterms:created>
    <dcterms:modified>2026-07-10</dcterms:modified>
    <dcterms:creator>Alessandro Bertozzi</dcterms:creator>
    <dcterms:contributor>Luca De Santis</dcterms:contributor>
    <dcterms:contributor>Silvio Peroni</dcterms:contributor>
    <owl:versionInfo>2.2.0</owl:versionInfo>
    <schema:creativeWorkStatus>Ontology Module</schema:creativeWorkStatus>
    <rdfs:comment xml:lang="en">A collection of data organized for research purposes in the Social Sciences and Humanities domain.</rdfs:comment>
    <rdfs:comment xml:lang="en">A dataset in the GoTriple platform, representing research data with specific metadata including spatial coverage, temporal coverage, and distribution information. It is a subclass of dcat:Dataset.</rdfs:comment>
