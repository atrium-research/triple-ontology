  {
    "@id": "https://gotriple.eu/ontology/triple/Dataset",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology",
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/abstract": [
      {
        "@language": "en",
        "@value": "The Dataset module of the TRIPLE Ontology, defining Datasets and Distributions aligned with DCAT."
      }
    ],
    "http://purl.org/dc/terms/contributor": [
      {
        "@value": "Luca De Santis"
      },
      {
        "@value": "Silvio Peroni"
      }
    ],
    "http://purl.org/dc/terms/created": [
      {
        "@value": "2021-12-01"
      }
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@value": "Alessandro Bertozzi"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "The Dataset module specializes in representing research data. It defines `triple:Dataset` as a connection point to the DCAT ontology, supporting the description of datasets, their distributions, temporal/spatial coverage, and access rights. This facilitates the discovery and reuse of research data within the SSH domain."
      }
    ],
    "http://purl.org/dc/terms/modified": [
      {
        "@value": "2026-07-10"
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@language": "en",
        "@value": "Dataset"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A collection of data organized for research purposes in the Social Sciences and Humanities domain."
      },
      {
        "@language": "en",
        "@value": "A dataset in the GoTriple platform, representing research data with specific metadata including spatial coverage, temporal coverage, and distribution information. It is a subclass of dcat:Dataset."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Dataset"
      },
      {
        "@language": "en",
        "@value": "Dataset (Triple)"
      },
      {
        "@language": "pt",
        "@value": "Base de Dados"
      },
      {
        "@language": "pl",
        "@value": "Zbiór Danych"
      },
      {
        "@language": "fr",
        "@value": "Jeu de Données"
      }
    ],
