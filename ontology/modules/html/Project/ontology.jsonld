  {
    "@id": "https://gotriple.eu/ontology/triple/Project",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology",
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/abstract": [
      {
        "@language": "en",
        "@value": "The Project module of the TRIPLE Ontology, defining Projects, Grants, and Funding."
      }
    ],
    "http://purl.org/dc/terms/contributor": [
      {
        "@value": "Luca De Santis"
      },
      {
        "@value": "Silvio Peroni"
      }
    ],
    "http://purl.org/dc/terms/created": [
      {
        "@value": "2021-12-01"
      }
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@value": "Alessandro Bertozzi"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "The Project module describes research projects and their funding structures. It defines the `triple:Project` class and links it to Grants (`schema:Grant`, `frapo:Grant`), Funding sources, and Organizations. It also includes the `triple:ProjectType` classification to categorize projects (e.g., EU-funded, National, Citizen Science)."
      }
    ],
    "http://purl.org/dc/terms/modified": [
      {
        "@value": "2025-12-22"
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@language": "en",
        "@value": "Project"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A research project in the Social Sciences and Humanities domain integrated into the GoTriple platform."
      },
      {
        "@language": "en",
        "@value": "A research project in the Social Sciences and Humanities domain integrated into the GoTriple platform. It is a subclass of schema:Project."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Project"
      },
      {
        "@language": "en",
        "@value": "Project (Triple)"
      },
