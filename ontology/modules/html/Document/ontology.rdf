  <owl:Ontology rdf:about="https://gotriple.eu/ontology/triple/Document">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Document</rdfs:label>
    <rdfs:label xml:lang="en">Document (Triple)</rdfs:label>
    <rdfs:label xml:lang="pt">Documento</rdfs:label>
    <rdfs:label xml:lang="pl">Dokument</rdfs:label>
    <rdfs:label xml:lang="fr">Document</rdfs:label>
    <dcterms:title xml:lang="en">Document</dcterms:title>
    <dcterms:abstract xml:lang="en">The Document module of the TRIPLE Ontology, defining the core Document class and shared definitions.</dcterms:abstract>
    <dcterms:description xml:lang="en">The Document module serves as the core of the TRIPLE Ontology. It defines the `triple:Document` class, representing scholarly publications and research outputs. Crucially, it also acts as the central hub for shared definitions used across the entire ontology, including Identifiers (DataCite), Licenses, Disciplines, and common schema.org properties.</dcterms:description>
    <dcterms:created>2021-12-01</dcterms:created>
    <dcterms:modified>2025-12-22</dcterms:modified>
    <dcterms:creator>Alessandro Bertozzi</dcterms:creator>
    <dcterms:contributor>Luca De Santis</dcterms:contributor>
    <dcterms:contributor>Silvio Peroni</dcterms:contributor>
    <owl:versionInfo>2.1.0</owl:versionInfo>
    <schema:creativeWorkStatus>Ontology Module</schema:creativeWorkStatus>
    <rdfs:comment xml:lang="en">A document in the GoTriple platform, representing scholarly publications and research outputs.</rdfs:comment>
    <rdfs:comment xml:lang="en">A document in the GoTriple platform, representing scholarly publications, research datasets, and other SSH research artifacts.</rdfs:comment>
    <rdfs:comment xml:lang="en">A document in the GoTriple platform, representing scholarly publications, research datasets, and other SSH research artifacts. It is a subclass of both schema:CreativeWork and foaf:Document.</rdfs:comment>
    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="nb93fe6c887de4b74a515c4f4fd871888b1">
        <owl:onProperty rdf:resource="https://schema.org/mentions"/>
