  {
    "@id": "https://gotriple.eu/ontology/triple/Document",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology",
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/abstract": [
      {
        "@language": "en",
        "@value": "The Document module of the TRIPLE Ontology, defining the core Document class and shared definitions."
      }
    ],
    "http://purl.org/dc/terms/contributor": [
      {
        "@value": "Luca De Santis"
      },
      {
        "@value": "Silvio Peroni"
      }
    ],
    "http://purl.org/dc/terms/created": [
      {
        "@value": "2021-12-01"
      }
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@value": "Alessandro Bertozzi"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "The Document module serves as the core of the TRIPLE Ontology. It defines the `triple:Document` class, representing scholarly publications and research outputs. Crucially, it also acts as the central hub for shared definitions used across the entire ontology, including Identifiers (DataCite), Licenses, Disciplines, and common schema.org properties."
      }
    ],
    "http://purl.org/dc/terms/modified": [
      {
        "@value": "2025-12-22"
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@language": "en",
        "@value": "Document"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A document in the GoTriple platform, representing scholarly publications and research outputs."
      },
      {
        "@language": "en",
        "@value": "A document in the GoTriple platform, representing scholarly publications, research datasets, and other SSH research artifacts."
      },
      {
        "@language": "en",
        "@value": "A document in the GoTriple platform, representing scholarly publications, research datasets, and other SSH research artifacts. It is a subclass of both schema:CreativeWork and foaf:Document."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Document"
      },
      {
        "@language": "en",
        "@value": "Document (Triple)"
      },
      {
        "@language": "pt",
        "@value": "Documento"
      },
      {
        "@language": "pl",
        "@value": "Dokument"
      },
      {
        "@language": "fr",
        "@value": "Document"
      }
