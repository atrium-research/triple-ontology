  {
    "@id": "https://gotriple.eu/ontology/triple/SemanticArtefact",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology",
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/abstract": [
      {
        "@language": "en",
        "@value": "The Semantic Artefact module of the TRIPLE Ontology, defining Ontologies, Vocabularies, and Thesauri."
      }
    ],
    "http://purl.org/dc/terms/contributor": [
      {
        "@value": "Luca De Santis"
      },
      {
        "@value": "Silvio Peroni"
      }
    ],
    "http://purl.org/dc/terms/created": [
      {
        "@value": "2021-12-01"
      }
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@value": "Alessandro Bertozzi"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "The Semantic Artefact module is dedicated to describing the semantic assets used or indexed by the GoTriple platform, such as ontologies, taxonomies, and thesauri. It extends the MOD (Metadata for Ontology Description) ontology to provide rich metadata about these knowledge organization systems, including their versioning, format, and status."
      }
    ],
    "http://purl.org/dc/terms/modified": [
      {
        "@value": "2025-12-22"
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@language": "en",
        "@value": "Semantic Artefact"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A semantic artefact in the context of GoTriple platform, representing formal knowledge representations such as ontologies, controlled vocabularies, and other semantic resources used in SSH research"
      },
      {
        "@language": "en",
        "@value": "A semantic artefact in the context of GoTriple platform, representing formal knowledge representations such as ontologies, controlled vocabularies, and other semantic resources used in SSH research."
      }
    ],
