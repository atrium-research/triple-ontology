  <owl:Ontology rdf:about="https://gotriple.eu/ontology/triple/SemanticArtefact">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Semantic Artefact</rdfs:label>
    <rdfs:label xml:lang="pt">Artefacto Semântico</rdfs:label>
    <rdfs:label xml:lang="pl">Artefakt Semantyczny</rdfs:label>
    <rdfs:label xml:lang="fr">Artefact Sémantique</rdfs:label>
    <dcterms:title xml:lang="en">Semantic Artefact</dcterms:title>
    <dcterms:abstract xml:lang="en">The Semantic Artefact module of the TRIPLE Ontology, defining Ontologies, Vocabularies, and Thesauri.</dcterms:abstract>
    <dcterms:description xml:lang="en">The Semantic Artefact module is dedicated to describing the semantic assets used or indexed by the GoTriple platform, such as ontologies, taxonomies, and thesauri. It extends the MOD (Metadata for Ontology Description) ontology to provide rich metadata about these knowledge organization systems, including their versioning, format, and status.</dcterms:description>
    <dcterms:created>2021-12-01</dcterms:created>
    <dcterms:modified>2025-12-22</dcterms:modified>
    <dcterms:creator>Alessandro Bertozzi</dcterms:creator>
    <dcterms:contributor>Luca De Santis</dcterms:contributor>
    <dcterms:contributor>Silvio Peroni</dcterms:contributor>
    <owl:versionInfo>2.1.0</owl:versionInfo>
    <schema:creativeWorkStatus>Ontology Module</schema:creativeWorkStatus>
    <rdfs:comment xml:lang="en">A semantic artefact in the context of GoTriple platform, representing formal knowledge representations such as ontologies, controlled vocabularies, and other semantic resources used in SSH research</rdfs:comment>
    <rdfs:comment xml:lang="en">A semantic artefact in the context of GoTriple platform, representing formal knowledge representations such as ontologies, controlled vocabularies, and other semantic resources used in SSH research.</rdfs:comment>
