  {
    "@id": "https://gotriple.eu/ontology/triple/MediaObject",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology",
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/abstract": [
      {
        "@language": "en",
        "@value": "The Media Object module of the TRIPLE Ontology, defining Audio, Video, and Image resources."
      }
    ],
    "http://purl.org/dc/terms/contributor": [
      {
        "@value": "Luca De Santis"
      },
      {
        "@value": "Silvio Peroni"
      }
    ],
    "http://purl.org/dc/terms/created": [
      {
        "@value": "2021-12-01"
      }
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@value": "Alessandro Bertozzi"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "The Media Object module manages multimedia resources within the platform. It defines the `triple:MediaObject` class for audio, video, and image content, providing properties to describe their technical characteristics (duration, size, encoding format) and intellectual content, aligned with `schema:MediaObject` and `fabio:Work`."
      }
    ],
    "http://purl.org/dc/terms/modified": [
      {
        "@value": "2025-12-22"
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@language": "en",
        "@value": "Media Object"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A media object such as an image, video, audio, or other multimedia content used in SSH research."
      },
      {
        "@language": "en",
        "@value": "A multimedia object in the GoTriple platform, representing various types of media files (audio, video, images) associated with scholarly works."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Media Object"
      },
      {
        "@language": "en",
        "@value": "Media Object (Triple)"
      },
