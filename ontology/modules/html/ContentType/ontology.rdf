  <owl:Ontology rdf:about="https://gotriple.eu/ontology/triple/ContentType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dcterms:title xml:lang="en">Content Type</dcterms:title>
    <dcterms:description xml:lang="en">The Content Type vocabulary categorizes the different types of resources available in the TRIPLE platform, such as journal articles, datasets, images, and video. It includes mappings to the COAR Resource Type Vocabulary to ensure interoperability.</dcterms:description>
    <dcterms:abstract xml:lang="en">A hierarchical controlled vocabulary for classifying the nature and genre of scholarly resources.</dcterms:abstract>
    <dcterms:creator>Alessandro Bertozzi</dcterms:creator>
    <dcterms:contributor>Luca De Santis</dcterms:contributor>
    <dcterms:contributor>Silvio Peroni</dcterms:contributor>
    <owl:versionInfo>2.2.0</owl:versionInfo>
    <vann:preferredNamespacePrefix>contenttype</vann:preferredNamespacePrefix>
    <vann:preferredNamespaceUri>https://gotriple.eu/ontology/triple/ContentType/</vann:preferredNamespaceUri>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-12-01</dcterms:created>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-07-10</dcterms:modified>
    <rdfs:label xml:lang="en">Content Type</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </owl:Ontology>
</rdf:RDF>
