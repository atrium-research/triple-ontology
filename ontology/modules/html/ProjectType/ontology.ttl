@prefix vann: <http://purl.org/vocab/vann/> .
@prefix pt: <https://gotriple.eu/ontology/triple/ProjectType/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix triple: <https://gotriple.eu/ontology/triple/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://gotriple.eu/ontology/triple/ProjectType> a owl:Ontology ;
    dcterms:title "Project Type"@en ;
    dcterms:description "The Project Type vocabulary defines the various categories of research projects included in the TRIPLE platform, distinguishing between different funding schemes and project structures."@en ;
    dcterms:abstract "A controlled vocabulary for classifying research projects."@en ;
    dcterms:creator "Alessandro Bertozzi" ;
    dcterms:contributor "Luca De Santis", "Silvio Peroni" ;
    owl:versionInfo "2.1.0" ;
    vann:preferredNamespacePrefix "projecttype" ;
    vann:preferredNamespaceUri "https://gotriple.eu/ontology/triple/ProjectType/" ;
    dcterms:created "2021-12-01"^^xsd:date ;
    dcterms:modified "2026-07-10"^^xsd:date .


triple:ProjectType a owl:Class ;
    rdfs:label "Project Type"@en ;
    rdfs:subClassOf skos:Concept .

pt: a owl:NamedIndividual, triple:ProjectType ;
    rdfs:label "Project Type"@en ;
    rdfs:comment "A generic project type categorization."@en .

pt:funded a owl:NamedIndividual,
        triple:ProjectType ;
    rdfs:label "Funded"@en ;
    rdfs:comment "A research project financed by a formal funding programme, such as a European or national grant."@en .

pt:non_funded a owl:NamedIndividual,
        triple:ProjectType ;
    rdfs:label "Non-funded"@en ;
    rdfs:comment "A research project carried out without dedicated external funding."@en .

pt:crowdfunded a owl:NamedIndividual,
        triple:ProjectType ;
    rdfs:label "Crowdfunded"@en ;
    rdfs:comment "A research project financed through collective contributions, typically via a crowdfunding platform."@en .

pt:citizen_science a owl:NamedIndividual,
        triple:ProjectType ;
    rdfs:label "Citizen Science"@en ;
    rdfs:comment "A research project conducted with the active participation of the general public."@en .

pt:community_based a owl:NamedIndividual,
        triple:ProjectType ;
    rdfs:label "Community-based"@en ;
    rdfs:comment "A research project initiated and driven by a community, typically outside formal institutional structures."@en .

pt:legacy a owl:NamedIndividual,
        triple:ProjectType ;
    rdfs:label "Legacy"@en ;
    rdfs:comment "A completed or historical research project included for archival and reference purposes."@en .

pt:institutional a owl:NamedIndividual,
        triple:ProjectType ;
    rdfs:label "Institutional"@en ;
    rdfs:comment "A research project funded or run internally by an institution, such as a university or research centre."@en .
