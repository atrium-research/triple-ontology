  {
    "@id": "https://gotriple.eu/ontology/triple/ProjectType/citizen_science",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://gotriple.eu/ontology/triple/ProjectType"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A research project conducted with the active participation of the general public."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Citizen Science"
      }
    ]
  },
  {
    "@id": "https://gotriple.eu/ontology/triple/ProjectType/institutional",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://gotriple.eu/ontology/triple/ProjectType"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A research project funded or run internally by an institution, such as a university or research centre."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Institutional"
      }
    ]
  },
  {
    "@id": "https://gotriple.eu/ontology/triple/ProjectType/funded",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://gotriple.eu/ontology/triple/ProjectType"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A research project financed by a formal funding programme, such as a European or national grant."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Funded"
      }
    ]
  },
  {
    "@id": "https://gotriple.eu/ontology/triple/ProjectType/community_based",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://gotriple.eu/ontology/triple/ProjectType"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A research project initiated and driven by a community, typically outside formal institutional structures."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Community-based"
      }
    ]
  },
  {
    "@id": "https://gotriple.eu/ontology/triple/ProjectType/non_funded",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://gotriple.eu/ontology/triple/ProjectType"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A research project carried out without dedicated external funding."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Non-funded"
      }
    ]
  },
  {
    "@id": "https://gotriple.eu/ontology/triple/ProjectType/legacy",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://gotriple.eu/ontology/triple/ProjectType"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A completed or historical research project included for archival and reference purposes."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Legacy"
      }
    ]
  },
  {
    "@id": "https://gotriple.eu/ontology/triple/ProjectType/crowdfunded",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual",
      "https://gotriple.eu/ontology/triple/ProjectType"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A research project financed through collective contributions, typically via a crowdfunding platform."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Crowdfunded"
      }
    ]
  },
