@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <https://schema.org/> .
@prefix datacite: <http://purl.org/spar/datacite/> .
@prefix litre: <http://purl.org/spar/literal/> .
@prefix triple: <https://gotriple.eu/ontology/triple/> .

# Identifier Pattern
# This pattern demonstrates how identifiers are handled in the TRIPLE ontology

# DataCite Identifier Pattern (only approach used in TRIPLE ontology)

# Main identifier property
datacite:hasIdentifier rdf:type owl:ObjectProperty ;
                       rdfs:label "datacite:hasIdentifier"@en ;
                       rdfs:comment "Links entities to their identifiers"@en ;
                       rdfs:range datacite:Identifier .

# Identifier scheme property  
# Identifier scheme property  
datacite:usesIdentifierScheme rdf:type owl:ObjectProperty ;
                             rdfs:label "datacite:usesIdentifierScheme"@en ;
                             rdfs:comment "Links an identifier to its scheme"@en ;
                             rdfs:domain datacite:Identifier ;
                             rdfs:range datacite:IdentifierScheme .

# Identifier class
datacite:Identifier rdf:type owl:Class ;
                   rdfs:label "datacite:Identifier"@en ;
                   rdfs:comment "An identifier that uniquely identifies an entity according to some identification scheme."@en .

# Usage Pattern in Classes
triple:Dataset rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty datacite:hasIdentifier ;
                               owl:allValuesFrom datacite:Identifier ] .

triple:MediaObject rdfs:subClassOf [ rdf:type owl:Restriction ;
                                   owl:onProperty datacite:hasIdentifier ;
                                   owl:allValuesFrom datacite:Identifier ] .

triple:SemanticArtefact rdfs:subClassOf [ rdf:type owl:Restriction ;
                                        owl:onProperty datacite:hasIdentifier ;
                                        owl:allValuesFrom datacite:Identifier ] .

# Example ABOX Structure:

# Typed identifier subclasses (preferred over bare datacite:Identifier)
triple:ID rdf:type owl:Class ;
          rdfs:label "Internal ID"@en ;
          rdfs:subClassOf datacite:Identifier .
triple:PID rdf:type owl:Class ;
           rdfs:label "Persistent ID"@en ;
           rdfs:subClassOf datacite:Identifier .
triple:OriginalIdentifier rdf:type owl:Class ;
           rdfs:label "Original Identifier"@en ;
           rdfs:subClassOf datacite:Identifier .
triple:DOI rdf:type owl:Class ;
           rdfs:label "DOI"@en ;
           rdfs:subClassOf datacite:Identifier .
# (also triple:Handle, triple:ISBN, triple:ISSN, triple:URI)

# Identifier schemes (named individuals; URL-based access uses dedicated schemes)
triple:internal_id_schema rdf:type datacite:IdentifierScheme ;
                   rdfs:label "TRIPLE Internal ID"@en .

datacite:doi rdf:type datacite:IdentifierScheme ;
           rdfs:label "datacite:doi"@en .

# triple:landing_page_url_schema / triple:full_text_url_schema / triple:source_url_schema
# carry the landing page, full text and source URLs of a resource.

# Identifier instances
triple:identifier-example rdf:type triple:ID ;
                         datacite:usesIdentifierScheme triple:internal_id_schema ;
                         litre:hasLiteralValue "TRIPLE_DOC_001" .

# Usage on entities
triple:example datacite:hasIdentifier triple:identifier-example .

# Pattern Notes:
# - Only DataCite model used (no schema:identifier strings)
# - Structured identifier management with schemes
# - Uses datacite:usesIdentifierScheme to link identifier to scheme
# - Uses litre:hasLiteralValue for the actual identifier string
# - Type identifiers with the project subclasses (triple:ID, triple:PID,
#   triple:OriginalIdentifier, triple:DOI, triple:Handle, triple:ISBN, triple:ISSN, triple:URI)
# - URLs (landing page, full text, source) are identifiers with dedicated URL schemes
# - Consistent across all main classes (Dataset, MediaObject, SemanticArtefact)
# - Better semantic modeling than simple string identifiers